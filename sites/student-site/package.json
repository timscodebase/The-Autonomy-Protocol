{
  "name": "student-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@autonomy/banner": "workspace:*",
    "@autonomy/footer": "workspace:*",
    "@autonomy/four-agreements": "workspace:*",
    "@autonomy/header": "workspace:*",
    "@autonomy/hero": "workspace:*",
    "@autonomy/logo": "workspace:*",
    "@autonomy/nav": "workspace:*",
    "@autonomy/pill": "workspace:*",
    "@autonomy/theme": "workspace:*",
    "@autonomy/twelve-steps": "workspace:*",
    "@lucide/svelte": "^1.8.0",
    "mdsvex": "^0.12.7"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@libsql/client": "^0.17.2",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.0"
}
